{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensciflow.org/schemas/environment-spec-v0.1.schema.json",
  "title": "OpenSciFlow Environment Spec v0.1",
  "type": "object",
  "required": ["type", "files", "hardware", "runtime_checks"],
  "properties": {
    "type": {
      "type": "array",
      "items": { "type": "string", "enum": ["conda", "apptainer", "docker", "module", "slurm", "local"] }
    },
    "files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "hardware": {
      "type": "object",
      "properties": {
        "cpu": { "type": "string" },
        "gpu": { "type": ["string", "null"] },
        "memory": { "type": "string" },
        "storage": { "type": "string" }
      },
      "additionalProperties": true
    },
    "runtime_checks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "hpc": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
